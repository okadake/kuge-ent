---
import Layout from '../layouts/Layout.astro';
---

<Layout title="お問い合わせ" description="久下耳鼻咽喉科へのお問い合わせフォームです。">
  <!-- Header -->
  <section class="py-6 md:py-8 bg-gradient-to-r from-primary-700 to-primary-600 text-white">
    <div class="container-max">
      <h1 class="text-4xl md:text-5xl font-normal mb-2">お問い合わせ</h1>
      <p class="text-lg text-white">
        ご質問やご不明な点はお気軽にお問い合わせください。
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="section-padding bg-white">
    <div class="container-max max-w-3xl">
      <!-- Contact Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div>
          <h2 class="text-2xl font-bold text-primary-900 mb-6">お電話でのお問い合わせ</h2>
          <p class="text-gray-700 mb-3">
            <span class="block font-bold text-primary-700 text-lg">
              <a href="tel:0466332777" class="hover:text-primary-600">TEL: 0466-33-2777</a>
            </span>
            <span class="block text-sm text-gray-600 mt-2">
              お気軽にお電話ください。
            </span>
          </p>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-primary-900 mb-6">アクセス情報</h2>
          <p class="text-gray-700 leading-relaxed">
            <span class="block font-bold text-primary-700 mb-2">住所</span>
            <span class="block mb-4">〒251-0028<br/>神奈川県藤沢市本鵠沼<br/>3-12-37 クリエート湘南第６ビル 2F</span>
            <span class="block font-bold text-primary-700 mb-2">最寄駅</span>
            <span class="block">小田急本鵠沼駅から徒歩7分</span>
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-primary-50 p-8 rounded-lg">
        <h2 class="text-2xl font-bold text-primary-900 mb-6">お問い合わせフォーム</h2>
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-primary-900 mb-2">
              お名前 <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-primary-300 rounded-lg focus:outline-none focus:border-primary-600 focus:ring-2 focus:ring-primary-200"
              placeholder="ご氏名"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-primary-900 mb-2">
              メールアドレス <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-primary-300 rounded-lg focus:outline-none focus:border-primary-600 focus:ring-2 focus:ring-primary-200"
              placeholder="example@example.com"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-primary-900 mb-2">
              電話番号
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-3 border border-primary-300 rounded-lg focus:outline-none focus:border-primary-600 focus:ring-2 focus:ring-primary-200"
              placeholder="090-0000-0000"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-primary-900 mb-2">
              件名 <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-3 border border-primary-300 rounded-lg focus:outline-none focus:border-primary-600 focus:ring-2 focus:ring-primary-200"
              placeholder="ご相談内容"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-primary-900 mb-2">
              メッセージ <span class="text-red-500">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              class="w-full px-4 py-3 border border-primary-300 rounded-lg focus:outline-none focus:border-primary-600 focus:ring-2 focus:ring-primary-200"
              placeholder="お問い合わせ内容をご入力ください。"
            ></textarea>
          </div>

          <div class="bg-white p-4 rounded-lg border border-primary-200">
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" name="privacy" required class="mt-1" />
              <span class="text-sm text-gray-700">
                <a href="#" class="text-primary-700 hover:text-primary-600">プライバシーポリシー</a>に同意します
              </span>
            </label>
          </div>

          <button
            type="submit"
            class="w-full px-6 py-3 bg-primary-700 text-white font-bold rounded-lg hover:bg-primary-600 active:bg-primary-800 smooth-transition"
          >
            送信する
          </button>
        </form>

        <p class="text-sm text-gray-600 text-center mt-6">
          <span class="text-red-500">*</span> は必須項目です
        </p>
      </div>

      <!-- Additional Info -->
      <div class="mt-12 p-6 bg-primary-100 rounded-lg border-l-4 border-primary-600">
        <h3 class="font-bold text-primary-900 mb-2">ご対応について</h3>
        <p class="text-sm text-gray-700">
          ご送信いただいたお問い合わせは、営業日の平日中にご返信させていただきます。
          お急ぎの場合はお電話（<a href="tel:0466332777" class="text-primary-700 font-bold hover:underline">0466-33-2777</a>）でお問い合わせください。
        </p>
      </div>
    </div>
  </section>
</Layout>
