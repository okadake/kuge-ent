---
import Layout from "../layouts/Layout.astro";
import News from "../components/News.astro";

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="ホーム">
  <!-- Hero Section -->
  <section
    class="relative bg-cover bg-center bg-no-repeat min-h-[300px] md:min-h-[400px] lg:min-h-[430px] flex items-start pt-0 md:pt-3"
    style={`background-image: url('${baseUrl}images/hero_bg01.jpg');`}
  >
    <!-- Foreground image -->
    <div class="absolute bottom-0 left-0 right-0 flex justify-center pointer-events-none">
      <img
        src={`${baseUrl}images/hero_front.png`}
        alt="Hero illustration"
        class="w-full max-w-[1600px] h-auto"
      />
    </div>

    <div class="container-max relative z-10 w-full">
      <div class="py-8 md:py-16 pl-1">
        <p class="text-2xl md:text-3xl lg:text-4xl font-bold mb-4 md:mb-5 !leading-[1.3] text-[#153d77]">ご安心<span class="tracking-[-0.55em]">、</span>ご納得いただける<br class="md:hidden">良質な医療を、<br>地域のみなさまに提供できる医院を目指しております。</p>
        <p class="text-base md:text-xl pl-1 mb-8 text-gray-800 font-bold">地元の皆様の「みみ・はな・のど」の<br class="md:hidden">健康管理のお役に立ちたいとおもいます。</p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white pt-6 pb-2">
    <div class="container-max max-w-6xl">
      <News />
    </div>
  </section>
  <!-- Features Section -->
  <section class="section-padding bg-white pt-4 pb-2">
    <div class="container-max max-w-6xl">
      <h2 class="text-xl md:text-2xl font-bold text-primary-900 mb-4 border-b-2 border-primary-900 pb-2">個別治療</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href={`${baseUrl}services/sublingual-immunotherapy`} class="p-8 bg-primary-200 rounded-lg hover:bg-primary-200 smooth-transition flex flex-col items-center justify-center">
          <h3 class="text-xl font-bold text-primary-800 my-0">舌下免疫療法</h3>
        </a>
        <a href={`${baseUrl}services/nasopharyngeal-b-spot-therapy`} class="p-8 bg-primary-200 rounded-lg hover:bg-primary-200 smooth-transition flex flex-col items-center justify-center">
          <h3 class="text-xl font-bold text-primary-800 my-0">上咽頭Bスポット療法</h3>
        </a>
        <a href={`${baseUrl}services/hearing-aid-clinic`} class="p-8 bg-primary-200 rounded-lg hover:bg-primary-200 smooth-transition flex flex-col items-center justify-center">
          <h3 class="text-xl font-bold text-primary-800 my-0">補聴器外来</h3>
        </a>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white pt-6 pb-1">
    <div class="container-max max-w-6xl">
      <h2 class="text-xl md:text-2xl font-bold text-primary-900 mb-4 border-b-2 border-primary-900 pb-2 ">診療時間</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse table-fixed">
          <thead class="">
            <tr class="bg-primary-700 text-white">
              <th class="font-normal pl-2 md:pl-4 py-2 w-20 md:w-56 text-center">窓口受付</th>
              <th class="font-normal px-0 py-2 text-center">月</th>
              <th class="font-normal px-0 py-2 text-center">火</th>
              <th class="font-normal px-0 py-2 text-center">水</th>
              <th class="font-normal px-0 py-2 text-center">木</th>
              <th class="font-normal px-0 py-2 text-center">金</th>
              <th class="font-normal px-0 py-2 text-center">土</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-primary-200 bg-primary-50">
              <td class="md:w-56 pl-1 md:pl-4 py-2 text-primary-800 whitespace-nowrap text-center">
                9:00<br><span class="text-xs">▼</span><br>12:00<br>
              </td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-primary-600">休</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
            </tr>
            <tr class="border-b border-primary-200">
              <td class="md:w-56 pl-1 md:pl-4 py-2 text-primary-800 whitespace-nowrap text-center">
                15:00<br><span class="text-xs">▼</span><br>18:00<br>
              </td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-primary-600">休<br class="md:hidden" />※</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-primary-600">休</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-primary-600">休</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-5 text-rose-500">ネット予約は各15分後〜終了30分前まで（午前9:15〜11:30、午後15:15〜17:30）</p>
      <p class="mt-5 text-base text-gray-700 leading-7">
        休診：木曜・日曜・祝日・火曜/土曜 午後<br>診療は午前 9:15～、午後は 15:15～<br>※ 連休明けの火曜午後は臨時診療
      </p>
    </div>
  </section>
  <section class="section-padding bg-white pt-3 pb-12">
    <div class="container-max max-w-6xl">
    <h2 class="text-xl md:text-2xl font-bold text-primary-900 mb-4 border-b-2 border-primary-900 pb-2 ">インフル予防接種問診票</h2>
    <p class="text-sm md:text-base text-gray-600 mb-6">ワクチン接種前にご確認いただき、診察時にご記入してご来院ください。</p>
    <a
      href="https://kuge-ent.jp/pdf/the_flu.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="w-full flex justify-center items-center gap-2 px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 smooth-transition md:w-1/2 md:mx-auto"
    >
      <svg class="w-5 h-10" viewBox="0 0 24 24" fill="white">
        <path d="M7 2h10a2 2 0 012 2v16a2 2 0 01-2 2H7a2 2 0 01-2-2V4a2 2 0 012-2z"/>
        <text x="12" y="16" font-size="9" font-weight="bold" text-anchor="middle" fill="#DC2626">PDF</text>
      </svg>
      インフル予防接種問診票（PDF）
    </a>
    
    </div>
  </section>
  </Layout>
