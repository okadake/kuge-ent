---
import Layout from "../layouts/Layout.astro";

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="ホーム">
  <!-- Hero Section -->
  <section
    class="section-padding relative bg-cover bg-center bg-no-repeat min-h-[400px] flex items-center"
    style={`background-image: url('${baseUrl}images/hero001.jpg')`}
  >
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="p-4 relative z-10">
      <div class="container-max max-w-6xl">
        <p class="text-4xl md:text-5xl lg:text-3xl font-bold mb-6 leading-tight text-white">ご安心、ご納得いただける良質な医療を、<br>地域のみなさまに提供できる医院を目指しております。</p>
        <p class="text-lg md:text-xl mb-8 text-gray-100">地元の皆様の「みみ・はな・のど」の健康管理のお役に立ちたいとおもいます。</p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white pt-6 pb-2">
    <div class="container-max max-w-6xl">
      <h2 class="text-xl md:text-2xl font-bold text-primary-900 mb-4 border-b-2 border-primary-900 pb-2">クリニックからのお知らせ</h2>
      <ul class="space-y-4">
        <li>
          <a href={`${baseUrl}information/`} class="text-primary-800 hover:text-primary-600 transition-colors duration-300">2024年6月1日　夏季休診のお知らせ</a>
        </li>
        <li>
          <a href={`${baseUrl}information/`} class="text-primary-800 hover:text-primary-600 transition-colors duration-300">2024年5月15日　新しい診療時間のご案内</a>
        </li>
        <li>
          <a href={`${baseUrl}information/`} class="text-primary-800 hover:text-primary-600 transition-colors duration-300">2024年4月10日　ゴールデンウィークの診療について</a>
        </li>
      </ul>
    </div>
  </section>
  <!-- Features Section -->
  <section class="section-padding bg-white pt-4 pb-2">
    <div class="container-max max-w-6xl">
      <h2 class="text-xl md:text-2xl font-bold text-primary-900 mb-4 border-b-2 border-primary-900 pb-2">個別治療</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href={`${baseUrl}services/sublingual-immunotherapy`} class="p-8 bg-primary-200 rounded-lg hover:bg-primary-200 smooth-transition flex flex-col items-center justify-center">
          <h3 class="text-xl font-bold text-primary-800 my-0">舌下免疫療法</h3>
        </a>
        <a href={`${baseUrl}services/nasopharyngeal-b-spot-therapy`} class="p-8 bg-primary-200 rounded-lg hover:bg-primary-200 smooth-transition flex flex-col items-center justify-center">
          <h3 class="text-xl font-bold text-primary-800 my-0">上咽頭Bスポット療法</h3>
        </a>
        <a href={`${baseUrl}services/hearing-aid-clinic`} class="p-8 bg-primary-200 rounded-lg hover:bg-primary-200 smooth-transition flex flex-col items-center justify-center">
          <h3 class="text-xl font-bold text-primary-800 my-0">補聴器外来</h3>
        </a>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white pt-6">
    <div class="container-max max-w-6xl">
      <h2 class="text-xl md:text-2xl font-bold text-primary-900 mb-4 border-b-2 border-primary-900 pb-2 ">診療時間</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse table-fixed">
          <thead class="">
            <tr class="bg-primary-700 text-white">
              <th class="font-normal pl-2 md:pl-4 py-2 text-left w-20 md:w-56  text-center">窓口受付</th>
              <th class="font-normal px-0 py-2 text-center">月</th>
              <th class="font-normal px-0 py-2 text-center">火</th>
              <th class="font-normal px-0 py-2 text-center">水</th>
              <th class="font-normal px-0 py-2 text-center">木</th>
              <th class="font-normal px-0 py-2 text-center">金</th>
              <th class="font-normal px-0 py-2 text-center">土</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-primary-200 bg-primary-50">
              <td class="md:w-56 pl-1 md:pl-4 py-2 text-primary-800 whitespace-nowrap text-center">
                9:00<br><span class="text-xs">▼</span><br>12:00<br>
              </td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-primary-600">休</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
            </tr>
            <tr class="border-b border-primary-200">
              <td class="md:w-56 pl-1 md:pl-4 py-2 text-primary-800 whitespace-nowrap text-center">
                15:00<br><span class="text-xs">▼</span><br>18:00<br>
              </td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-primary-600">休<br class="md:hidden" />※</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-primary-600">休</span></td>
              <td class="px-0 py-2 text-center"><span class="text-base text-primary-600">●</span></td>
              <td class="px-0 py-2 text-center"><span class="text-primary-600">休</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-5 text-base text-primary-700 leading-7">
        休診：木曜・日曜・祝日・火曜/土曜 午後<br /> ※ 連休明けの火曜午後は臨時診療<br>
        診療は午前 9:15～、午後は 15:15～
      </p>
    </div>
  </section></Layout
>
