---
const baseUrl = import.meta.env.BASE_URL;
import Layout from '../layouts/Layout.astro';

interface NewsItem {
  date: string;
  title: string;
  content: string;
}

const news: NewsItem[] = [
  {
    date: '2024.03.03',
    title: '発熱患者様へのお願い',
    content: '初診再診にかかわらず、この2,3日熱のある方は来院前に電話をお願いします。',
  },
  {
    date: '2023.12.21',
    title: '連休明けの火曜午後診療について',
    content: '2024年より、連休明けの火曜午後は臨時診療いたします。',
  },
];
---
const baseUrl = import.meta.env.BASE_URL;

<Layout title="ニュース" description="久下耳鼻咽喉科のお知らせとニュースです。">
  <!-- Header -->
  <section class="py-6 md:py-8 bg-gradient-to-r from-primary-700 to-primary-600 text-white">
    <div class="container-max">
      <h1 class="text-4xl md:text-5xl font-normal mb-2">ニュース</h1>
      <p class="text-lg text-white">
        当院からのお知らせと最新情報をお届けします。
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="section-padding bg-white">
    <div class="container-max max-w-3xl">
      <div class="space-y-6">
        {news.map((item) => (
          <article class="pb-6 border-b border-primary-200 last:border-b-0">
            <div class="flex flex-col md:flex-row md:items-start gap-4">
              <time class="text-sm font-bold text-primary-600 min-w-fit md:pt-1">
                {item.date}
              </time>
              <div class="flex-1">
                <h3 class="text-lg font-bold text-primary-800 mb-2 hover:text-primary-600 smooth-transition">
                  {item.title}
                </h3>
                <p class="text-gray-700 leading-relaxed">
                  {item.content}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Call to Action -->
      <div class="mt-12 p-8 bg-primary-50 rounded-lg text-center border-l-4 border-primary-600">
        <h2 class="text-xl font-bold text-primary-900 mb-3">
          その他のご質問・ご相談は
        </h2>
        <p class="text-gray-700 mb-6">
          当院スタッフまでお気軽にお問い合わせください。
        </p>
        <a href="/contact/" class="inline-block px-8 py-3 bg-primary-700 text-white font-bold rounded-lg hover:bg-primary-600 smooth-transition">
          お問い合わせページへ
        </a>
      </div>
    </div>
  </section>
</Layout>
