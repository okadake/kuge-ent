---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '本鵠沼耳鼻咽喉科 - みみ・はな・のどの健康管理' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} - 本鵠沼耳鼻咽喉科</title>
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --primary-900: #1b453e;
    --primary-800: #245d55;
    --primary-700: #2d7c6f;
    --primary-600: #3a9b89;
    --primary-500: #4db8a8;
    --primary-50: #f0f7f6;
  }
</style>
