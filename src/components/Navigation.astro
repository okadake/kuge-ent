---
const baseUrl = import.meta.env.BASE_URL;
const navItems = [
  { name: '診療案内', href: `${baseUrl}information/` },
  { name: '院長あいさつ', href: `${baseUrl}about/` },
  { name: '院内設備', href: `${baseUrl}facilities/` },
];
---

<!-- Desktop Navigation -->
<nav class="hidden md:block">
  <ul class="flex gap-8">
    {navItems.map(item => (
      <li>
        <a
          href={item.href}
          class="text-lg font-bold text-gray-700 hover:text-primary-700 smooth-transition"
        >
          {item.name}
        </a>
      </li>
    ))}
  </ul>
</nav>
